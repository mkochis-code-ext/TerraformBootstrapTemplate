# Whether to create a new resource group or use an existing one
create_resource_group = true

# Resource group name for the Terraform state storage account
resource_group_name = "rg-tfstate"

# Storage account name (must be globally unique, 3-24 lowercase alphanumeric characters)
storage_account_name = "stterraformstate"

# Azure region
location = "eastus"

# Tags
tags = {
  ManagedBy = "Terraform"
  Purpose   = "TerraformState"
}
