# Whether to create a new resource group or use an existing one
create_resource_group = true

# Resource group name for the Terraform state storage accounts
resource_group_name = "rg-tfstate"

# Storage account names (must each be globally unique, 3-24 lowercase alphanumeric characters).
# Add or remove names independently — for_each ensures only the changed account is affected.
storage_account_names = [
  "stterraformstate1",
  "stterraformstate2",
]

# Azure region
location = "eastus"

# Tags
tags = {
  ManagedBy = "Terraform"
  Purpose   = "TerraformState"
}
